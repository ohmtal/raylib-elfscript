   /** --- Vector3 Vector3Reject ---
    * Calculate the rejection of the vector v1 on to v2
    * @return Vector3
    */
      function Vector3Reject( Vector3 v1, Vector3 v2 );
   /** --- Vector3 Vector3Transform ---
    * Transforms a Vector3 by a given Matrix
    * @return Vector3
    */
      function Vector3Transform( Vector3 v1, Matrix mat );
   /** --- Vector3 Vector3RotateByQuaternion ---
    * Transform a vector by quaternion rotation
    * @return Vector3
    */
      function Vector3RotateByQuaternion( Vector3 v1, Vector4 v2 );
   /** --- Vector3 Vector3RotateByAxisAngle ---
    * Rotates a vector around an axis
    * @return Vector3
    */
      function Vector3RotateByAxisAngle( Vector3 v1, Vector3 axis, float angle );
   /** --- Vector3 Vector3MoveTowards ---
    * Move Vector towards target
    * @return Vector3
    */
      function Vector3MoveTowards( Vector3 v1, Vector3 v2, float maxDistance );
};
