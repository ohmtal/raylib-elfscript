};
class  Camera2DObject : public SimObject {
  public:
   /** --- Vector2 getWorldToScreen ---
    * Get 2D screen space position for a 2D camera world space position
    * @return Vector2
    */
      function getWorldToScreen( Vector2 position );
   /** --- Vector2 getScreenToWorld ---
    * Get 2D world space position for a 2D camera screen space position (e.g. mouse to world)
    * @return Vector2
    */
      function getScreenToWorld( Vector2 position );
   /** --- Matrix getCameraMatrix ---
    * Get the 2D camera transform matrix
    * @return Matrix
    */
      function getCameraMatrix();
   // --- Group: Ungrouped ---
   // --- Group: Object ---
   // --- Group: Editing ---
   // --- Group: Persistence ---
   /*!
   Camera screen offset
   
    */
   Vector2 offset;
   /*!
   Camera world target
   
    */
   Vector2 target;
   /*!
   Camera rotation in degrees
   
    */
   float rotation;
   /*!
   Camera zoom level
   
    */
